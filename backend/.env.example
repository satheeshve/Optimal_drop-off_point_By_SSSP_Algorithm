# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/commuter_genius
REDIS_URL=redis://localhost:6379

# Security
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8081

# GTFS and GTFS-RT (set either GTFS_STATIC_URL or GTFS_STATIC_PATH)
GTFS_STATIC_URL=
GTFS_STATIC_PATH=
GTFS_RT_VEHICLE_POSITIONS_URL=
GTFS_RT_API_KEY=
GTFS_RT_API_KEY_HEADER=x-api-key
GTFS_TIMEOUT_SECONDS=12
GTFS_STATIC_CACHE_TTL_SECONDS=1800

# Safety Configuration
HAZARD_IMPACT_RADIUS_KM=2.0
DUPLICATE_DETECTION_RADIUS_M=50
DUPLICATE_DETECTION_TIME_MIN=30
MAX_REPORTS_PER_HOUR=5
MIN_CREDIBILITY_THRESHOLD=0.4

# Emergency Configuration
SOS_ACTIVATION_DELAY_SECONDS=5
LOCATION_UPDATE_INTERVAL_SECONDS=10
